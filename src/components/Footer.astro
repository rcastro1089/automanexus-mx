---
import { defaultConfig } from '../data/siteConfig';

const waLink = `https://wa.me/${defaultConfig.whatsapp}?text=${encodeURIComponent(defaultConfig.whatsappMessage)}`;
const year = new Date().getFullYear();

const nichos = [
  { href: '/dentistas/', label: 'Dentistas' },
  { href: '/abogados/', label: 'Abogados' },
  { href: '/veterinarias/', label: 'Veterinarias' },
  { href: '/estetica/', label: 'Estética' },
  { href: '/inmobiliarias/', label: 'Inmobiliarias' },
];
---

<footer class="border-t border-white/5 bg-bg-secondary mt-20">
  <div class="container-mx py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-2 font-extrabold text-lg mb-4">
          <span class="w-8 h-8 rounded-lg bg-gradient-to-br from-accent-primary to-accent-secondary flex items-center justify-center text-white text-sm font-black">A</span>
          <span data-brand>AutomaNexus</span>
        </a>
        <p class="text-text-secondary text-sm max-w-sm leading-relaxed">
          Páginas web profesionales para negocios en México. Diseño custom, SEO local, y pago mensual. Tu web te consigue clientes en Google.
        </p>
        <a href={waLink} data-wa-link target="_blank" rel="noopener"
           class="inline-flex items-center gap-2 mt-4 text-sm text-accent-success hover:text-accent-primary transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          Escríbenos por WhatsApp
        </a>
      </div>

      <!-- Sectores -->
      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wider text-text-muted mb-4">Sectores</h3>
        <ul class="space-y-2">
          {nichos.map(n => (
            <li><a href={n.href} class="text-sm text-text-secondary hover:text-white transition-colors">{n.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Links -->
      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wider text-text-muted mb-4">Enlaces</h3>
        <ul class="space-y-2">
          <li><a href="/precios/" class="text-sm text-text-secondary hover:text-white transition-colors">Precios</a></li>
          <li><a href="/faq/" class="text-sm text-text-secondary hover:text-white transition-colors">Preguntas Frecuentes</a></li>
          <li><a href="/contacto/" class="text-sm text-text-secondary hover:text-white transition-colors">Contacto</a></li>
          <li><a href="/admin/" class="text-sm text-text-muted hover:text-white transition-colors">Administrar</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-text-muted">© {year} AutomaNexus. Hecho con <span class="text-accent-danger">❤</span> en LATAM.</p>
      <p class="text-sm text-text-muted">Diseño web profesional · Hosting en CDN global · 🇲🇽 México</p>
    </div>
  </div>
</footer>
