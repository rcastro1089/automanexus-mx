---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import StickyMobile from '../components/StickyMobile.astro';
import { defaultConfig } from '../data/siteConfig';

const waLink = `https://wa.me/${defaultConfig.whatsapp}?text=${encodeURIComponent(defaultConfig.whatsappMessage)}`;
---

<BaseLayout
  title="Contacto | AutomaNexus"
  description="Escríbenos por WhatsApp y te respondemos en minutos. Diseño web profesional para tu negocio en México."
  noindex={false}
>
  <Nav />

  <main>
    <section class="py-20 lg:py-32 grid-pattern">
      <div class="container-mx">
        <div class="max-w-2xl mx-auto text-center">
          <span class="reveal text-5xl block mb-6">💬</span>
          <h1 class="reveal text-4xl sm:text-5xl font-black tracking-tight mb-6">
            Hablemos por <span class="gradient-text">WhatsApp</span>
          </h1>
          <p class="reveal text-lg text-text-secondary mb-8">
            Es la forma más rápida. Nos escribes, te respondemos en minutos, y te contamos cómo puede quedar tu web. Sin formularios largos ni esperas de 48 horas.
          </p>

          <div class="reveal flex flex-col items-center gap-4">
            <a href={waLink} data-wa-link target="_blank" rel="noopener" class="btn-primary text-lg px-10 py-5">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
              Abrir WhatsApp
            </a>
            <p class="text-sm text-text-muted">⚡ Respuesta en menos de 30 minutos en horario laboral</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Otras opciones -->
    <section class="py-16 lg:py-24 border-t border-white/5">
      <div class="container-mx max-w-3xl">
        <div class="reveal text-center mb-12">
          <h2 class="section-title">¿Prefieres otra vía?</h2>
          <p class="section-sub mx-auto">También puedes contactarnos así:</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="reveal card text-center">
            <span class="text-3xl block mb-3">📧</span>
            <h3 class="font-bold mb-2">Email</h3>
            <a href={`mailto:${defaultConfig.email}`} data-email class="text-accent-primary hover:text-accent-secondary transition-colors text-sm break-all">
              {defaultConfig.email}
            </a>
          </div>
          <div class="reveal card text-center">
            <span class="text-3xl block mb-3">🕐</span>
            <h3 class="font-bold mb-2">Horario</h3>
            <p class="text-text-secondary text-sm">Lunes a Viernes<br />9:00 AM — 7:00 PM (Hora México)</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <StickyMobile />
</BaseLayout>
