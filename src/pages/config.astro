---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Configuración | AutomaNexus" description="Panel de configuración" noindex={true}>
  <Nav />

  <main>
    <section class="py-12 lg:py-20">
      <div class="container-mx max-w-2xl">
        <!-- Login gate -->
        <div id="login-gate" class="reveal card">
          <h1 class="text-2xl font-bold mb-2">🔒 Panel de Configuración</h1>
          <p class="text-text-secondary text-sm mb-6">Ingresa la contraseña para acceder.</p>
          <input id="config-password" type="password" placeholder="Contraseña"
                 class="w-full px-4 py-3 rounded-xl bg-bg-tertiary border border-white/10 text-white placeholder-text-muted focus:outline-none focus:border-accent-primary transition-colors mb-4" />
          <button id="config-login-btn" class="btn-primary w-full justify-center">Entrar</button>
          <p id="login-error" class="text-accent-danger text-sm mt-3 hidden">Contraseña incorrecta.</p>
        </div>

        <!-- Config panel (hidden until auth) -->
        <div id="config-panel" class="hidden space-y-6">
          <div class="flex items-center justify-between">
            <h1 class="text-2xl font-bold">⚙️ Configuración</h1>
            <button id="config-logout" class="text-sm text-text-muted hover:text-white">Cerrar</button>
          </div>

          <div class="card space-y-5">
            <h2 class="font-bold text-lg">Contacto</h2>

            <div>
              <label class="block text-sm font-medium text-text-secondary mb-2">Número de WhatsApp (con código de país, sin +)</label>
              <input id="cfg-whatsapp" type="text" placeholder="521234567890"
                     class="w-full px-4 py-3 rounded-xl bg-bg-tertiary border border-white/10 text-white placeholder-text-muted focus:outline-none focus:border-accent-primary transition-colors" />
            </div>

            <div>
              <label class="block text-sm font-medium text-text-secondary mb-2">Mensaje de WhatsApp pre-llenado</label>
              <textarea id="cfg-wa-message" rows="3" placeholder="Hola, quiero información..."
                        class="w-full px-4 py-3 rounded-xl bg-bg-tertiary border border-white/10 text-white placeholder-text-muted focus:outline-none focus:border-accent-primary transition-colors"></textarea>
            </div>

            <div>
              <label class="block text-sm font-medium text-text-secondary mb-2">Email de contacto</label>
              <input id="cfg-email" type="email" placeholder="hola@automanex.us"
                     class="w-full px-4 py-3 rounded-xl bg-bg-tertiary border border-white/10 text-white placeholder-text-muted focus:outline-none focus:border-accent-primary transition-colors" />
            </div>
          </div>

          <div class="card space-y-5">
            <h2 class="font-bold text-lg">Marca</h2>

            <div>
              <label class="block text-sm font-medium text-text-secondary mb-2">Nombre de la marca</label>
              <input id="cfg-brand" type="text" placeholder="AutomaNexus"
                     class="w-full px-4 py-3 rounded-xl bg-bg-tertiary border border-white/10 text-white placeholder-text-muted focus:outline-none focus:border-accent-primary transition-colors" />
            </div>

            <div>
              <label class="block text-sm font-medium text-text-secondary mb-2">Ciudad principal</label>
              <input id="cfg-city" type="text" placeholder="México"
                     class="w-full px-4 py-3 rounded-xl bg-bg-tertiary border border-white/10 text-white placeholder-text-muted focus:outline-none focus:border-accent-primary transition-colors" />
            </div>
          </div>

          <div class="card space-y-5">
            <h2 class="font-bold text-lg">Precios (USD)</h2>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-text-secondary mb-2">Presencia - Setup</label>
                <input id="cfg-presencia-setup" type="number" placeholder="99"
                       class="w-full px-4 py-3 rounded-xl bg-bg-tertiary border border-white/10 text-white placeholder-text-muted focus:outline-none focus:border-accent-primary transition-colors" />
              </div>
              <div>
                <label class="block text-sm font-medium text-text-secondary mb-2">Presencia - Mensual</label>
                <input id="cfg-presencia-monthly" type="number" placeholder="25"
                       class="w-full px-4 py-3 rounded-xl bg-bg-tertiary border border-white/10 text-white placeholder-text-muted focus:outline-none focus:border-accent-primary transition-colors" />
              </div>
              <div>
                <label class="block text-sm font-medium text-text-secondary mb-2">Profesional - Setup</label>
                <input id="cfg-profesional-setup" type="number" placeholder="199"
                       class="w-full px-4 py-3 rounded-xl bg-bg-tertiary border border-white/10 text-white placeholder-text-muted focus:outline-none focus:border-accent-primary transition-colors" />
              </div>
              <div>
                <label class="block text-sm font-medium text-text-secondary mb-2">Profesional - Mensual</label>
                <input id="cfg-profesional-monthly" type="number" placeholder="50"
                       class="w-full px-4 py-3 rounded-xl bg-bg-tertiary border border-white/10 text-white placeholder-text-muted focus:outline-none focus:border-accent-primary transition-colors" />
              </div>
              <div>
                <label class="block text-sm font-medium text-text-secondary mb-2">Premium - Setup</label>
                <input id="cfg-premium-setup" type="number" placeholder="399"
                       class="w-full px-4 py-3 rounded-xl bg-bg-tertiary border border-white/10 text-white placeholder-text-muted focus:outline-none focus:border-accent-primary transition-colors" />
              </div>
              <div>
                <label class="block text-sm font-medium text-text-secondary mb-2">Premium - Mensual</label>
                <input id="cfg-premium-monthly" type="number" placeholder="80"
                       class="w-full px-4 py-3 rounded-xl bg-bg-tertiary border border-white/10 text-white placeholder-text-muted focus:outline-none focus:border-accent-primary transition-colors" />
              </div>
            </div>

            <div class="flex items-center gap-3 pt-2">
              <input id="cfg-show-prices" type="checkbox" class="w-5 h-5 rounded accent-accent-primary" />
              <label for="cfg-show-prices" class="text-sm text-text-secondary">Mostrar precios en la web</label>
            </div>
          </div>

          <div class="flex gap-4">
            <button id="config-save" class="btn-primary flex-1 justify-center">💾 Guardar configuración</button>
            <button id="config-reset" class="btn-secondary">↺ Restaurar valores por defecto</button>
          </div>

          <div id="save-status" class="text-center text-sm hidden"></div>

          <div class="card bg-bg-tertiary border-dashed">
            <p class="text-text-muted text-xs leading-relaxed">
              💡 Los cambios se guardan en este navegador (localStorage). Se aplican instantáneamente a la web cuando la visites desde este navegador. Para cambios permanentes en el servidor, contacta al administrador.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script is:inline>
    const PASSWORD_HASH = 'a64e5a5c3d0f3d6e9c1b4a7d8e2f5a6b'; // automanexus2026 (simple hash for demo)

    // Simple hash function (not crypto-secure, just obfuscation)
    function simpleHash(str) {
      let hash = 0;
      for (let i = 0; i < str.length; i++) {
        const char = str.charCodeAt(i);
        hash = ((hash << 5) - hash) + char;
        hash = hash & hash;
      }
      return hash.toString(16);
    }

    const SESSION_KEY = 'an_config_auth';

    // Check if already authed
    function checkAuth() {
      if (sessionStorage.getItem(SESSION_KEY) === '1') {
        showPanel();
      }
    }

    function showPanel() {
      document.getElementById('login-gate')?.classList.add('hidden');
      document.getElementById('config-panel')?.classList.remove('hidden');
      loadConfig();
    }

    function loadConfig() {
      try {
        const stored = localStorage.getItem('an_config');
        const cfg = stored ? JSON.parse(stored) : {};
        document.getElementById('cfg-whatsapp').value = cfg.whatsapp || '1234567890';
        document.getElementById('cfg-wa-message').value = cfg.whatsappMessage || 'Hola, vi su página AutomaNexus y quiero información sobre páginas web para mi negocio';
        document.getElementById('cfg-email').value = cfg.email || 'hola@automanex.us';
        document.getElementById('cfg-brand').value = cfg.brandName || 'AutomaNexus';
        document.getElementById('cfg-city').value = cfg.city || 'México';
        document.getElementById('cfg-show-prices').checked = cfg.showPrices !== false;
        document.getElementById('cfg-presencia-setup').value = cfg.prices?.presencia?.setup || 99;
        document.getElementById('cfg-presencia-monthly').value = cfg.prices?.presencia?.monthly || 25;
        document.getElementById('cfg-profesional-setup').value = cfg.prices?.profesional?.setup || 199;
        document.getElementById('cfg-profesional-monthly').value = cfg.prices?.profesional?.monthly || 50;
        document.getElementById('cfg-premium-setup').value = cfg.prices?.premium?.setup || 399;
        document.getElementById('cfg-premium-monthly').value = cfg.prices?.premium?.monthly || 80;
      } catch(e) {
        console.error('Load error:', e);
      }
    }

    function saveConfig() {
      const cfg = {
        whatsapp: document.getElementById('cfg-whatsapp').value,
        whatsappMessage: document.getElementById('cfg-wa-message').value,
        email: document.getElementById('cfg-email').value,
        brandName: document.getElementById('cfg-brand').value,
        city: document.getElementById('cfg-city').value,
        showPrices: document.getElementById('cfg-show-prices').checked,
        prices: {
          presencia: {
            setup: parseInt(document.getElementById('cfg-presencia-setup').value) || 99,
            monthly: parseInt(document.getElementById('cfg-presencia-monthly').value) || 25,
          },
          profesional: {
            setup: parseInt(document.getElementById('cfg-profesional-setup').value) || 199,
            monthly: parseInt(document.getElementById('cfg-profesional-monthly').value) || 50,
          },
          premium: {
            setup: parseInt(document.getElementById('cfg-premium-setup').value) || 399,
            monthly: parseInt(document.getElementById('cfg-premium-monthly').value) || 80,
          },
        }
      };
      localStorage.setItem('an_config', JSON.stringify(cfg));
      const status = document.getElementById('save-status');
      status.textContent = '✅ Guardado. Los cambios se aplican a la web inmediatamente.';
      status.className = 'text-center text-sm text-accent-success';
      setTimeout(() => status.classList.add('hidden'), 3000);
    }

    function resetConfig() {
      localStorage.removeItem('an_config');
      const status = document.getElementById('save-status');
      status.textContent = '↺ Restaurado. Recarga la página para ver los valores por defecto.';
      status.className = 'text-center text-sm text-accent-warning';
      status.classList.remove('hidden');
      setTimeout(() => { loadConfig(); }, 1000);
    }

    // Login handler
    document.getElementById('config-login-btn')?.addEventListener('click', () => {
      const pw = document.getElementById('config-password').value;
      if (pw === 'automanexus2026') {
        sessionStorage.setItem(SESSION_KEY, '1');
        showPanel();
      } else {
        const err = document.getElementById('login-error');
        err?.classList.remove('hidden');
        setTimeout(() => err?.classList.add('hidden'), 3000);
      }
    });

    document.getElementById('config-password')?.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') document.getElementById('config-login-btn')?.click();
    });

    document.getElementById('config-save')?.addEventListener('click', saveConfig);
    document.getElementById('config-reset')?.addEventListener('click', resetConfig);
    document.getElementById('config-logout')?.addEventListener('click', () => {
      sessionStorage.removeItem(SESSION_KEY);
      location.reload();
    });

    checkAuth();
  </script>
</BaseLayout>
